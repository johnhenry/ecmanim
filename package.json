{
  "name": "manim-js",
  "version": "0.1.0",
  "description": "A JavaScript port of manim (Mathematical Animation Engine). Runs in Node (renders to MP4 via ffmpeg) and in the browser (live canvas + WebM export).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./node": { "types": "./dist/node.d.ts", "default": "./dist/node.js" },
    "./browser": { "types": "./dist/browser.d.ts", "default": "./dist/browser.js" },
    "./browser-three": { "types": "./dist/browser-three.d.ts", "default": "./dist/browser-three.js" }
  },
  "bin": {
    "manim-js": "./bin/manim-js.ts"
  },
  "files": ["dist", "src", "bin"],
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "test": "node --test 'test/**/*.test.ts'",
    "example": "node examples/basic.ts"
  },
  "keywords": [
    "manim",
    "animation",
    "math",
    "canvas",
    "3blue1brown",
    "bezier"
  ],
  "license": "MIT",
  "optionalDependencies": {
    "@napi-rs/canvas": "^0.1.100",
    "three": "^0.185.1"
  },
  "dependencies": {
    "mathjax-full": "^3.2.1",
    "opentype.js": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "typescript": "^6.0.3"
  }
}
